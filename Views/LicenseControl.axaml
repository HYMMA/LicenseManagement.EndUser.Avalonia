<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LicenseManagement.EndUser.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="400"
             x:Class="LicenseManagement.EndUser.Avalonia.Views.LicenseControl"
             x:DataType="vm:LicenseViewModel"
             x:Name="ThisControl">

  <UserControl.Styles>
    <StyleInclude Source="avares://LicenseManagement.EndUser.Avalonia/Themes/LicenseTheme.axaml" />
  </UserControl.Styles>

  <Border Classes="card" Background="{StaticResource CardBackgroundBrush}">
    <StackPanel Spacing="16">
      <!-- Header with Status Badge -->
      <DockPanel LastChildFill="True">
        <Border Background="{StaticResource IconBlueBackgroundBrush}"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,16,8"
                DockPanel.Dock="Left"
                VerticalAlignment="Top">
          <PathIcon Width="22" Height="22"
                    Foreground="{StaticResource PrimaryBrush}"
                    Data="{StaticResource LicenseDocumentIcon}" />
        </Border>

        <StackPanel VerticalAlignment="Center" Margin="0,0,0,8">
          <TextBlock Text="License Status" Classes="heading" FontSize="16" />
          <Border Classes="status-badge"
                  Margin="0,6,0,0"
                  HorizontalAlignment="Left"
                  Background="{Binding Status, Converter={StaticResource LicenseStatusToBackgroundConverter}}"
                  BorderBrush="{Binding Status, Converter={StaticResource LicenseStatusToBorderConverter}}"
                  BorderThickness="1"
                  Padding="10,6">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{Binding Status, Converter={StaticResource LicenseStatusToIconConverter}}"
                         FontWeight="Bold"
                         FontSize="12"
                         Foreground="{Binding Status, Converter={StaticResource LicenseStatusToBorderConverter}}" />
              <TextBlock Text="{Binding Status, Converter={StaticResource LicenseStatusToTextConverter}}"
                         FontWeight="SemiBold"
                         FontSize="12"
                         TextWrapping="Wrap"
                         Foreground="{Binding Status, Converter={StaticResource LicenseStatusToBorderConverter}}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </DockPanel>

      <!-- Separator -->
      <Border Height="1" Background="{StaticResource BorderBrush}" />

      <!-- License Details -->
      <StackPanel Spacing="10">
        <StackPanel IsVisible="{Binding Status, Converter={StaticResource LicenseStatusToSubscriptionVisibilityConverter}}"
                    Spacing="10">
          <WrapPanel Orientation="Horizontal">
            <TextBlock Text="Customer: " Classes="label" VerticalAlignment="Center" />
            <TextBlock Text="{Binding CustomerEmail}" Classes="value" TextWrapping="Wrap" />
          </WrapPanel>
          <WrapPanel Orientation="Horizontal">
            <TextBlock Text="Subscription Expires: " Classes="label" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ReceiptExpires, Converter={StaticResource NullableDateTimeToStringConverter}}"
                       Classes="value" />
          </WrapPanel>
        </StackPanel>

        <WrapPanel Orientation="Horizontal"
                   IsVisible="{Binding Status, Converter={StaticResource LicenseStatusToTrialVisibilityConverter}}">
          <TextBlock Text="Trial Expires: " Classes="label" VerticalAlignment="Center" />
          <TextBlock Text="{Binding TrialExpires, Converter={StaticResource NullableDateTimeToStringConverter}}"
                     Classes="value" />
        </WrapPanel>

        <WrapPanel Orientation="Horizontal">
          <TextBlock Text="License File Expires: " Classes="label" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Expires, Converter={StaticResource NullableDateTimeToStringConverter}}"
                     Classes="value" />
        </WrapPanel>

        <WrapPanel Orientation="Horizontal">
          <TextBlock Text="Computer: " Classes="label" VerticalAlignment="Center" />
          <TextBlock Text="{Binding ComputerName}" Classes="value" TextWrapping="Wrap" />
        </WrapPanel>

        <WrapPanel Orientation="Horizontal">
          <TextBlock Text="Product: " Classes="label" VerticalAlignment="Center" Margin="0,0,8,0" />
          <ComboBox Classes="modern"
                    ItemsSource="{Binding Products}"
                    SelectedItem="{Binding Product}"
                    MinWidth="140">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:ProductViewModel">
                <TextBlock Text="{Binding Name}" Padding="8,4" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </WrapPanel>

        <WrapPanel Orientation="Horizontal">
          <TextBlock Text="Vendor: " Classes="label" VerticalAlignment="Center" />
          <TextBlock Text="{Binding VendorName}" Classes="value" />
        </WrapPanel>
      </StackPanel>

      <Border Height="1" Background="{StaticResource BorderBrush}" />

      <!-- Action Buttons -->
      <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Register License"
                Classes="primary"
                Margin="0,4,8,4"
                Command="{Binding ShowRegisterViewCommand}"
                CommandParameter="{Binding #ThisControl}"
                IsVisible="{Binding Status, Converter={StaticResource LicenseStatusToRegisterVisibilityConverter}}" />

        <Button Content="Release License"
                Classes="secondary"
                Margin="0,4,8,4"
                Command="{Binding ShowUnregisterViewCommand}"
                CommandParameter="{Binding #ThisControl}"
                IsVisible="{Binding Status, Converter={StaticResource LicenseStatusToUnregisterVisibilityConverter}}" />

        <Button Content="Download New File"
                Classes="primary"
                Margin="0,4,0,4"
                Command="{Binding RenewLicenseFileCommand}"
                CommandParameter="{Binding #ThisControl}"
                IsVisible="{Binding Status, Converter={StaticResource LicenseStatusToRenewVisibilityConverter}}" />
      </WrapPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <TextBlock Text="Powered by " Classes="muted" />
        <TextBlock Text="License-Management.com" Classes="muted" FontWeight="Medium" />
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
